[Unit]
Description=Ticket Booking frontend (Next.js)
After=network.target

[Service]
User=debian
Group=debian
WorkingDirectory=/home/debian/code/ticket-booking/frontend
Environment=NODE_ENV=production
EnvironmentFile=/home/debian/code/ticket-booking/frontend/.env.production
ExecStart=/usr/bin/env npm run start -- -p 3000
Restart=always
RestartSec=3

[Install]
WantedBy=multi-user.target
